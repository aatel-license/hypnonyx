# --- Situation Overrides ---
SITUATION_RETRO_LLM=lm_studio
SITUATION_RESEARCH_LLM=default

USE_UNIVERSAL_AGENTS=true

# Message Broker Configuration
USE_KAFKA=false
USE_MQTT=false  # Set to 'true' if you have MQTT broker running

# Kafka Settings (if enabled)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MQTT Settings (if enabled)
MQTT_BROKER=localhost
MQTT_PORT=1883

# Agent Configuration
MAX_IDLE_TIME=30
HEARTBEAT_INTERVAL=5
MAX_ITERATIONS=10

# Execution Configuration
EXEC_TIMEOUT=60
MAX_JSON_RETRY=3

# Git Configuration
GIT_AUTO_COMMIT=true
GIT_BRANCH_PREFIX=agent

# Auto-Fix Configuration
MAX_RETRIES=3
REDIS_URL=redis://localhost:6379/0

# Sprint 
SPRINT_SIZE=5  # 5 (1 sprint every 5 task)
BACKLOG_REFINEMENT_INTERVAL=1  #5 (1 refinement every 5 sprint)
RELEASE_SPRINT_INTERVAL=1 #(1 release every 5 sprint)



# OpenSearch
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=changeme

# OpenSearch Dashboards
OPENSEARCH_DASHBOARD_USER=admin
OPENSEARCH_DASHBOARD_PASSWORD=changeme
USETOON=false
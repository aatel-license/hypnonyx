# LLM Configuration
# LM Studio or any OpenAI-compatible API
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
LM_STUDIO_MODEL_NAME=local-model
TEMPERATURE=0.3
LLM_STUDIO_KEY=  # Bearer token (leave empty for local unauthenticated instances)
REQUEST_PER_MINUTE=20
USE_MULTI_PROVIDER=true
# Comma-separated list of active profiles from config.LLM_PROFILES
ACTIVE_LLM_PROFILES=default,sambanova,anthropic,lm_studio

# --- Multi-Provider LLM Profiles ---

# SambaNova (e.g., Llama 3.3 70B)
SAMBANOVA_URL=https://api.sambanova.ai/v1/chat/completions
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
SAMBANOVA_KEY=
SAMBANOVA_RPM=12

# Anthropic (e.g., Claude 3.5 Sonnet via shim)
ANTHROPIC_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
ANTHROPIC_API_KEY=
ANTHROPIC_RPM=5

# LM Studio / Local LLM
LOCAL_LLM_URL=http://localhost:1234/v1/chat/completions
LOCAL_LLM_MODEL=local-model
LOCAL_LLM_RPM=60

# --- Agent to LLM Mapping ---
AGENT_BACKEND_LLM=default
AGENT_FRONTEND_LLM=default
AGENT_ORCHESTRATOR_LLM=default
AGENT_ARCHITECT_LLM=default
AGENT_SCRUM_LLM=default
AGENT_DATABASE_LLM=default
AGENT_DEVOPS_LLM=default
AGENT_QA_LLM=default
AGENT_RESEARCHER_LLM=default
AGENT_REVIEWER_LLM=default
AGENT_TESTING_LLM=default
AGENT_UNIVERSAL_LLM=default

# --- Extensive LLM Providers ---

# Free Providers
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=meta-llama/llama-3.1-405b
OPENROUTER_API_KEY=
OPENROUTER_RPM=10

GOOGLE_AI_STUDIO_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
GOOGLE_AI_STUDIO_MODEL=gemini-1.5-pro
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_RPM=15

